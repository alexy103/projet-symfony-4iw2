{% extends 'base.html.twig' %}

{% block title %}Connexion — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto">
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-8">
            <div class="text-center mb-6">
                <div class="text-4xl">🤥</div>
                <h1 class="mt-2 text-2xl font-extrabold text-slate-900">Connexion</h1>
                <p class="mt-1 text-sm text-slate-500">Reprenez vos meilleures excuses là où vous les aviez laissées.</p>
            </div>

            {% if error %}
                <div class="mb-4 border border-red-300 bg-red-50 text-red-800 rounded-md px-4 py-3 text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="mb-4 border border-blue-300 bg-blue-50 text-blue-800 rounded-md px-4 py-3 text-sm">
                    Vous êtes déjà connecté en tant que {{ app.user.userIdentifier }}.
                    <a href="{{ logout_path() }}" class="font-semibold underline">Se déconnecter</a>
                </div>
            {% endif %}

            <form method="post" class="space-y-4">
                <div>
                    <label for="username" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="username"
                           autocomplete="email" required autofocus
                           class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Mot de passe</label>
                    <input type="password" name="_password" id="password"
                           autocomplete="current-password" required
                           class="w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none">
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button type="submit"
                        class="w-full px-4 py-2.5 rounded-md bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
                    Se connecter
                </button>
            </form>
        </div>
    </div>
{% endblock %}
