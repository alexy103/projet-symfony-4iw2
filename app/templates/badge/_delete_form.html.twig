<form method="post" action="{{ path('app_badge_delete', {id: badge.id}) }}"
      onsubmit="return confirm('Supprimer ce badge ?');" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ badge.id) }}">
    <button type="submit" class="px-3 py-1.5 rounded-md text-red-600 hover:bg-red-50 text-sm transition">Supprimer</button>
</form>
