{% extends 'base.html.twig' %}

{% block title %}Attribuer « {{ badge.name }} » — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-2xl mx-auto">
        <div class="mb-6">
            <a href="{{ path('app_badge_index') }}" class="text-sm text-slate-500 hover:text-slate-700">← Retour aux badges</a>
            <h1 class="text-2xl font-extrabold text-slate-900 mt-2">Attribuer un badge</h1>
            <p class="text-slate-600">Cochez les utilisateurs qui possèdent le badge
                <span class="font-semibold">{{ badge.name }}</span>.</p>
        </div>

        <form method="post" class="bg-white rounded-xl border border-slate-200 shadow-sm divide-y divide-slate-100">
            <input type="hidden" name="_token" value="{{ csrf_token('recipients' ~ badge.id) }}">

            {% for user in users %}
                {% set has = badge.users.contains(user) %}
                <label class="flex items-center gap-3 px-5 py-3 hover:bg-slate-50 cursor-pointer">
                    <input type="checkbox" name="users[]" value="{{ user.id }}" {{ has ? 'checked' : '' }}
                           class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                    <span class="flex-1 text-sm text-slate-800">{{ user.userIdentifier }}</span>
                    <span class="flex flex-wrap gap-1 justify-end">
                        {% for role in user.roles %}
                            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-xs">{{ role }}</span>
                        {% endfor %}
                    </span>
                </label>
            {% endfor %}

            <div class="px-5 py-4 flex items-center gap-3">
                <button type="submit"
                        class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition">
                    Enregistrer
                </button>
                <a href="{{ path('app_badge_index') }}" class="text-sm text-slate-500 hover:text-slate-700">Annuler</a>
            </div>
        </form>
    </div>
{% endblock %}
