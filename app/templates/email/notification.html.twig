<!DOCTYPE html>
<html lang="fr">
<body style="font-family: Arial, sans-serif; background:#f1f5f9; padding:24px;">
    <div style="max-width:520px; margin:0 auto; background:#ffffff; border:1px solid #e2e8f0; border-radius:12px; padding:24px;">
        <div style="font-size:28px;">🤥</div>
        <h1 style="font-size:20px; color:#0f172a; margin:8px 0 16px;">{{ title }}</h1>
        <p style="color:#334155; font-size:14px;">Bonjour {{ user.userIdentifier }},</p>
        <p style="color:#334155; font-size:14px; line-height:1.5;">{{ message }}</p>
        <hr style="border:none; border-top:1px solid #e2e8f0; margin:20px 0;">
        <p style="color:#94a3b8; font-size:12px;">Excusatron 3000 — cet e-mail vous a été envoyé automatiquement.</p>
    </div>
</body>
</html>
