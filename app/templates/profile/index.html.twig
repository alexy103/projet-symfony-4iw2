{% extends 'base.html.twig' %}

{% block title %}Mon profil — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-3xl mx-auto space-y-8">
        <div class="flex items-center gap-4">
            <div class="w-16 h-16 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-3xl">
                🤥
            </div>
            <div>
                <h1 class="text-2xl font-extrabold text-slate-900">Mon profil</h1>
                <p class="text-slate-500">{{ app.user.userIdentifier }}</p>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
            <h2 class="font-bold text-lg text-slate-900 mb-4">Informations</h2>
            <dl class="grid sm:grid-cols-2 gap-4 text-sm">
                <div>
                    <dt class="text-slate-500">Email</dt>
                    <dd class="font-medium text-slate-800">{{ app.user.userIdentifier }}</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Rôles</dt>
                    <dd class="flex flex-wrap gap-1 mt-1">
                        {% for role in app.user.roles %}
                            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-700 text-xs font-medium">{{ role }}</span>
                        {% endfor %}
                    </dd>
                </div>
            </dl>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
            <h2 class="font-bold text-lg text-slate-900 mb-4">
                Mes badges
                <span class="text-slate-400 font-normal text-sm">({{ app.user.badges|length }})</span>
            </h2>

            {% if app.user.badges is empty %}
                <p class="text-sm text-slate-500">Aucun badge pour l'instant. Mentez mieux, ça viendra.</p>
            {% else %}
                <div class="grid sm:grid-cols-2 gap-4">
                    {% for badge in app.user.badges %}
                        <div class="flex items-start gap-3 border border-slate-200 rounded-lg p-4">
                            <div class="text-2xl">{{ badge.icon|default('🏅') }}</div>
                            <div>
                                <div class="font-semibold text-slate-800">{{ badge.name }}</div>
                                {% if badge.description %}
                                    <div class="text-sm text-slate-500">{{ badge.description }}</div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
