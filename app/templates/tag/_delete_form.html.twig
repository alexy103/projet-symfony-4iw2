<form method="post" action="{{ path('app_tag_delete', {id: tag.id}) }}"
      onsubmit="return confirm('Supprimer ce tag ?');" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tag.id) }}">
    <button type="submit" class="px-3 py-1.5 rounded-md text-red-600 hover:bg-red-50 transition">Supprimer</button>
</form>
