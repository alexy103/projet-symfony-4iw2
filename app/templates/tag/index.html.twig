{% extends 'base.html.twig' %}

{% block title %}Tags — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-extrabold text-slate-900">Tags</h1>
                <p class="text-sm text-slate-500">Les tags globaux et vos tags personnels.</p>
            </div>
            <a href="{{ path('app_tag_new') }}"
               class="px-4 py-2 rounded-md bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition">
                {{ is_granted('ROLE_ADMIN') ? '+ Nouveau tag global' : '+ Nouveau tag' }}
            </a>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 text-slate-500 text-left">
                    <tr>
                        <th class="px-4 py-3 font-medium">Tag</th>
                        <th class="px-4 py-3 font-medium">Type</th>
                        <th class="px-4 py-3 font-medium">Couleur</th>
                        <th class="px-4 py-3 font-medium text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for tag in tags %}
                        {% set can_manage = tag.global ? is_granted('ROLE_ADMIN') : (tag.owner and app.user and tag.owner.id == app.user.id) %}
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold text-white"
                                      style="background-color: {{ tag.color|default('#64748b') }}">
                                    {{ tag.name }}
                                </span>
                            </td>
                            <td class="px-4 py-3">
                                {% if tag.global %}
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 text-xs font-medium">🌐 Global</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-700 text-xs font-medium">👤 Personnel</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-slate-500 font-mono">{{ tag.color|default('—') }}</td>
                            <td class="px-4 py-3">
                                <div class="flex items-center justify-end gap-2">
                                    {% if can_manage %}
                                        <a href="{{ path('app_tag_edit', {id: tag.id}) }}"
                                           class="px-3 py-1.5 rounded-md bg-slate-100 hover:bg-slate-200 transition">Modifier</a>
                                        {{ include('tag/_delete_form.html.twig') }}
                                    {% else %}
                                        <span class="text-xs text-slate-300">—</span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-4 py-8 text-center text-slate-400">
                                Aucun tag pour l'instant.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
