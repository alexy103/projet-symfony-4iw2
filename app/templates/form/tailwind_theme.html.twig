{% use 'form_div_layout.html.twig' %}

{% block form_label %}
    {%- if label is not same as(false) -%}
        {% set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' block text-sm font-medium text-slate-700 mb-1')|trim}) %}
    {%- endif -%}
    {{ parent() }}
{% endblock %}

{% block form_widget_simple %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block textarea_widget %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none')|trim, rows: attr.rows|default(4)}) %}
    {{ parent() }}
{% endblock %}

{% block choice_widget_collapsed %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' w-full rounded-md border border-slate-300 px-3 py-2 text-sm bg-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block checkbox_widget %}
    {% set attr = attr|merge({class: (attr.class|default('') ~ ' w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500')|trim}) %}
    {{ parent() }}
{% endblock %}

{% block form_help %}
    {%- if help is not empty -%}
        {% set help_attr = help_attr|merge({class: (help_attr.class|default('') ~ ' text-xs text-slate-400 mt-1')|trim}) %}
    {%- endif -%}
    {{ parent() }}
{% endblock %}

{% block form_errors %}
    {%- if errors|length > 0 -%}
        <ul class="mt-1 text-sm text-red-600 list-disc list-inside">
            {%- for error in errors -%}
                <li>{{ error.message }}</li>
            {%- endfor -%}
        </ul>
    {%- endif -%}
{% endblock %}
