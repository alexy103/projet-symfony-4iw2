{{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
    <div>
        {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
        {{ form_widget(form.email, {'attr': {'class': 'w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none'}}) }}
        {{ form_errors(form.email) }}
    </div>

    <div>
        {{ form_label(form.plainPassword.first, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
        {{ form_widget(form.plainPassword.first, {'attr': {'class': 'w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none'}}) }}
        {{ form_errors(form.plainPassword.first) }}
    </div>

    <div>
        {{ form_label(form.plainPassword.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-slate-700 mb-1'}}) }}
        {{ form_widget(form.plainPassword.second, {'attr': {'class': 'w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none'}}) }}
        {{ form_errors(form.plainPassword.second) }}
    </div>

    {% if form.roles is defined %}
        <div>
            <span class="block text-sm font-medium text-slate-700 mb-2">Rôles</span>
            <div class="space-y-2">
                {{ form_widget(form.roles) }}
            </div>
            {{ form_errors(form.roles) }}
        </div>
    {% endif %}

    {{ form_rest(form) }}

    <button class="w-full px-4 py-2.5 rounded-md bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">{{ button_label|default('Enregistrer') }}</button>
{{ form_end(form) }}
