{% extends 'base.html.twig' %}

{% block title %}Détail excuse{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold">{{ excuse.title }}</h1>
        <span class="text-xs px-2 py-1 rounded bg-slate-100">{{ excuse.status }}</span>
    </div>

    <div class="bg-white border rounded-lg p-4 space-y-3">
        <p><span class="font-semibold">Auteur :</span> {{ excuse.author.email }}</p>
        <p><span class="font-semibold">Catégorie :</span> {{ excuse.category.name }}</p>
        <p><span class="font-semibold">Contexte :</span> {{ excuse.context.name }}</p>
        <p><span class="font-semibold">Ton :</span> {{ excuse.tone.name }}</p>
        <p><span class="font-semibold">Urgence :</span> {{ excuse.urgencyLevel }}</p>
        <p><span class="font-semibold">Créée le :</span> {{ excuse.createdAt|date('d/m/Y H:i') }}</p>
        {% if excuse.updatedAt %}
            <p><span class="font-semibold">Dernière mise à jour :</span> {{ excuse.updatedAt|date('d/m/Y H:i') }}</p>
        {% endif %}
        <p><span class="font-semibold">Contenu :</span></p>
        <p class="text-slate-700">{{ excuse.content }}</p>
        {% if excuse.status == 'rejected' %}
            <p class="text-sm text-red-700 bg-red-50 border border-red-200 rounded p-2">
                <span class="font-semibold">Motif du rejet :</span>
                {{ rejectionReason ?: 'Aucun commentaire n\'a été saisi par le validateur.' }}
            </p>
        {% endif %}
    </div>

    {% if is_granted('EXCUSE_VALIDATE', excuse) %}
        <div class="mt-4 grid md:grid-cols-2 gap-3">
            <form method="post" action="{{ path('app_validator_excuse_accept', {'id': excuse.id}) }}" class="p-3 border rounded-md bg-green-50">
                <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ excuse.id) }}">
                <label class="text-sm font-medium text-green-900" for="accept_comment_show_{{ excuse.id }}">Commentaire (optionnel)</label>
                <textarea id="accept_comment_show_{{ excuse.id }}" name="comment" rows="2" class="w-full mt-1 border rounded px-2 py-1"></textarea>
                <button type="submit" class="mt-2 px-3 py-2 rounded bg-green-600 text-white hover:bg-green-700 transition">Accepter</button>
            </form>

            <form method="post" action="{{ path('app_validator_excuse_reject', {'id': excuse.id}) }}" class="p-3 border rounded-md bg-red-50">
                <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ excuse.id) }}">
                <label class="text-sm font-medium text-red-900" for="reject_comment_show_{{ excuse.id }}">Motif du rejet (optionnel)</label>
                <textarea id="reject_comment_show_{{ excuse.id }}" name="comment" rows="2" class="w-full mt-1 border rounded px-2 py-1"></textarea>
                <button type="submit" class="mt-2 px-3 py-2 rounded bg-red-600 text-white hover:bg-red-700 transition">Rejeter</button>
            </form>
        </div>
    {% endif %}

    <div class="mt-4 flex gap-3">
        <a href="{{ path('app_my_excuses') }}" class="px-4 py-2 rounded-md bg-slate-200 hover:bg-slate-300">Retour</a>
        {% if is_granted('EXCUSE_EDIT', excuse) %}
            <a href="{{ path('app_excuse_edit', {'id': excuse.id}) }}" class="px-4 py-2 rounded-md bg-amber-500 text-white hover:bg-amber-600">Modifier</a>
            {% if excuse.status == 'rejected' %}
                <form method="post" action="{{ path('app_excuse_resubmit', {'id': excuse.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('resubmit' ~ excuse.id) }}">
                    <button class="px-4 py-2 rounded-md bg-indigo-600 text-white hover:bg-indigo-700" type="submit">Resoumettre</button>
                </form>
            {% endif %}
        {% endif %}
        {% if is_granted('EXCUSE_DELETE', excuse) %}
            <form method="post" action="{{ path('app_excuse_delete', {'id': excuse.id}) }}" onsubmit="return confirm('Confirmer la suppression ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ excuse.id) }}">
                <button class="px-4 py-2 rounded-md bg-red-600 text-white hover:bg-red-700" type="submit">Supprimer</button>
            </form>
        {% endif %}
    </div>
{% endblock %}

