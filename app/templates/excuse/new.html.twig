{% extends 'base.html.twig' %}

{% block title %}Nouvelle excuse — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-3xl mx-auto">
        <h1 class="text-2xl font-extrabold text-slate-900">Nouvelle excuse</h1>
        <p class="text-sm text-slate-500 mt-1 mb-6">Choisissez d'abord le type d'excuse à créer.</p>

        <div class="grid md:grid-cols-3 gap-4">
            {% set types = [
                { key: 'classic',      icon: '🙂', title: 'Classique',       text: "Une excuse du quotidien : retard, oubli, petit imprévu." },
                { key: 'emergency',    icon: '🚨', title: 'Urgente',         text: "Une excuse dramatique : panne, urgence, incident de dernière minute." },
                { key: 'professional', icon: '💼', title: 'Professionnelle', text: "Une excuse orientée travail : réunion manquée, deadline ratée." },
            ] %}
            {% for type in types %}
                <a href="{{ path('app_excuse_new_type', {'type': type.key}) }}"
                   class="group bg-white border border-slate-200 rounded-xl p-5 shadow-sm hover:border-indigo-400 hover:shadow transition">
                    <div class="text-3xl">{{ type.icon }}</div>
                    <h2 class="mt-3 font-bold text-slate-900 group-hover:text-indigo-600 transition">{{ type.title }}</h2>
                    <p class="text-sm text-slate-600 mt-1">{{ type.text }}</p>
                </a>
            {% endfor %}
        </div>
    </div>
{% endblock %}
