{% set statusValue = status|default('') %}
{% set statusLabel = {
    'pending': 'En attente',
    'validated': 'Validée',
    'rejected': 'Rejetée'
}[statusValue]|default('Inconnu') %}
{% set statusBadge = {
    'pending': 'bg-sky-50 text-sky-700 border-sky-200',
    'validated': 'bg-green-50 text-green-700 border-green-200',
    'rejected': 'bg-red-50 text-red-700 border-red-200'
}[statusValue]|default('bg-slate-50 text-slate-700 border-slate-200') %}

<span class="text-xs px-2 py-1 rounded border {{ statusBadge }}">{{ statusLabel }}</span>


