{% extends 'base.html.twig' %}

{% block title %}{{ excuse.title }} — Excusatron 3000{% endblock %}

{% block body %}
    <div class="max-w-3xl mx-auto space-y-6">
        <a href="{{ path('app_excuse_preview_index') }}" class="text-sm text-slate-500 hover:text-slate-700">← Retour aux excuses</a>

        <article class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
            <div class="flex items-start justify-between gap-3">
                <h1 class="text-2xl font-extrabold text-slate-900">{{ excuse.title }}</h1>
                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 shrink-0">{{ excuse.status }}</span>
            </div>
            <p class="text-xs text-slate-400 mt-1">par {{ excuse.author.userIdentifier }} · {{ excuse.createdAt|date('d/m/Y à H:i') }}</p>

            <div class="flex flex-wrap gap-2 mt-3 text-xs">
                {% if excuse.category %}<span class="px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-700">{{ excuse.category.name }}</span>{% endif %}
                {% if excuse.context %}<span class="px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">{{ excuse.context.name }}</span>{% endif %}
                {% if excuse.tone %}<span class="px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">{{ excuse.tone.name }}</span>{% endif %}
            </div>

            <p class="mt-4 text-slate-700 whitespace-pre-line">{{ excuse.content }}</p>
        </article>

        {{ include('excuse/_rating.html.twig') }}
        {{ include('excuse/_comments.html.twig') }}
    </div>
{% endblock %}
