{% extends 'base.html.twig' %}

{% block title %}Liste des excuses{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold">Toutes les excuses</h1>
        <a href="{{ path('app_excuse_new') }}" class="px-4 py-2 rounded-md bg-indigo-600 text-white hover:bg-indigo-700 transition">Nouvelle excuse</a>
    </div>

    <form method="get" class="grid md:grid-cols-4 xl:grid-cols-8 gap-3 mb-6 p-4 bg-white border rounded-lg">
        <input type="text" name="q" value="{{ filters.keyword|default('') }}" placeholder="Recherche..." class="border rounded px-3 py-2">
        <select name="type" class="border rounded px-3 py-2">
            <option value="">Tous les types</option>
            {% for typeValue, typeLabel in {
                'classic': 'Classique',
                'emergency': 'Urgence',
                'professional': 'Professionnel'
            } %}
                <option value="{{ typeValue }}" {% if filters.type|default('') == typeValue %}selected{% endif %}>{{ typeLabel }}</option>
            {% endfor %}
        </select>

        <select name="categoryId" class="border rounded px-3 py-2">
            <option value="">Toutes les catégories</option>
            {% for category in categories %}
                <option value="{{ category.id }}" {% if filters.categoryId|default('') == (category.id ~ '') %}selected{% endif %}>{{ category.name }}</option>
            {% endfor %}
        </select>

        <select name="contextId" class="border rounded px-3 py-2">
            <option value="">Tous les contextes</option>
            {% for context in contexts %}
                <option value="{{ context.id }}" {% if filters.contextId|default('') == (context.id ~ '') %}selected{% endif %}>{{ context.name }}</option>
            {% endfor %}
        </select>

        <select name="toneId" class="border rounded px-3 py-2">
            <option value="">Tous les tons</option>
            {% for tone in tones %}
                <option value="{{ tone.id }}" {% if filters.toneId|default('') == (tone.id ~ '') %}selected{% endif %}>{{ tone.name }}</option>
            {% endfor %}
        </select>

        <select name="sort" class="border rounded px-3 py-2">
            {% for sortValue, sortLabel in {
                'recent': 'Plus récentes',
                'oldest': 'Plus anciennes',
                'credibility_desc': 'Crédibilité décroissante',
                'credibility_asc': 'Crédibilité croissante',
                'title_asc': 'Titre A → Z',
                'title_desc': 'Titre Z → A'
            } %}
                <option value="{{ sortValue }}" {% if filters.sort|default('recent') == sortValue %}selected{% endif %}>{{ sortLabel }}</option>
            {% endfor %}
        </select>

        {% if is_granted('ROLE_ADMIN') %}
            <select name="status" class="border rounded px-3 py-2">
                <option value="">Tous les statuts</option>
                {% for statusValue, statusLabel in {
                    'pending': 'En attente',
                    'validated': 'Validée',
                    'rejected': 'Rejetée'
                } %}
                    <option value="{{ statusValue }}" {% if filters.status|default('') == statusValue %}selected{% endif %}>{{ statusLabel }}</option>
                {% endfor %}
            </select>
        {% endif %}

        <button class="px-4 py-2 rounded-md bg-slate-800 text-white">Filtrer</button>
        <a href="{{ path('app_excuse_index') }}" class="px-4 py-2 rounded-md bg-slate-200 text-center">Réinitialiser</a>
    </form>

    {% if excuses is empty %}
        <p class="text-slate-500">Aucune excuse trouvée.</p>
    {% else %}
        <div class="space-y-3">
            {% for excuse in excuses %}
                <a href="{{ path('app_excuse_show', {'id': excuse.id}) }}" class="relative block p-4 bg-white border rounded-lg hover:border-indigo-300 hover:shadow-sm transition">
                    <article>
                        <div class="absolute top-4 right-4">
                            {{ include('excuse/_type_badge.html.twig', {type: excuseTypes[excuse.id]|default('')}) }}
                        </div>
                        <div class="flex items-center gap-2 pr-32">
                            <h2 class="font-semibold">{{ excuse.title }}</h2>
                            {{ include('excuse/_status_badge.html.twig', {status: excuse.status}) }}
                        </div>
                        <p class="text-sm text-slate-600 mt-1">Par {{ excuse.author.email }} — {{ excuse.createdAt|date('d/m/Y H:i') }}</p>
                        <p class="mt-2 text-slate-700">{{ excuse.content|slice(0, 180) }}{% if excuse.content|length > 180 %}...{% endif %}</p>
                    </article>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}

