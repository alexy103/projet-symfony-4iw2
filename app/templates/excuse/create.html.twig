{% extends 'base.html.twig' %}

{% block title %}Créer une excuse — Excusatron 3000{% endblock %}

{% block body %}
    {% set typeLabels = {classic: 'classique', emergency: 'urgente', professional: 'professionnelle'} %}
    <div class="max-w-2xl mx-auto">
        <a href="{{ path('app_excuse_new') }}" class="text-sm text-slate-500 hover:text-slate-700">← Changer de type</a>
        <h1 class="text-2xl font-extrabold text-slate-900 mt-2 mb-6">Créer une excuse {{ typeLabels[type]|default(type) }}</h1>

        <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-6">
            {{ include('excuse/_form.html.twig', {form: form, type: type}) }}
        </div>
    </div>
{% endblock %}
