{% set statusValue = status|default('') %}
{% set typeValue = type|default('') %}

{% set statusLabel = {
    'pending': 'En attente',
    'validated': 'Validée',
    'rejected': 'Rejetée'
}[statusValue]|default('Inconnu') %}

{% set statusBadge = {
    'pending': 'bg-sky-50 text-sky-700 border-sky-200',
    'validated': 'bg-green-50 text-green-700 border-green-200',
    'rejected': 'bg-red-50 text-red-700 border-red-200'
}[statusValue]|default('bg-slate-50 text-slate-700 border-slate-200') %}

{% set typeBadge = {
    'classic': 'bg-blue-50 text-blue-700 border-blue-200',
    'emergency': 'bg-orange-50 text-orange-700 border-orange-200',
    'professional': 'bg-violet-50 text-violet-700 border-violet-200'
}[typeValue]|default('bg-slate-50 text-slate-700 border-slate-200') %}

{% set typeLabel = {
    'classic': 'Classique',
    'emergency': 'Urgence',
    'professional': 'Professionnel'
}[typeValue]|default('Inconnu') %}

<div class="flex items-center gap-1">
    <span class="text-xs px-2 py-1 rounded border {{ statusBadge }}">{{ statusLabel }}</span>
    <span class="text-xs px-2 py-1 rounded border {{ typeBadge }}">{{ typeLabel }}</span>
</div>



