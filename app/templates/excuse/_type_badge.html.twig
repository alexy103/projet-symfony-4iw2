{% set typeValue = type|default('') %}
{% set typeBadge = {
    'classic': 'bg-blue-50 text-blue-700 border-blue-200',
    'emergency': 'bg-orange-50 text-orange-700 border-orange-200',
    'professional': 'bg-violet-50 text-violet-700 border-violet-200'
}[typeValue]|default('bg-slate-50 text-slate-700 border-slate-200') %}
{% set typeLabel = {
    'classic': 'Classique',
    'emergency': 'Urgence',
    'professional': 'Professionnel'
}[typeValue]|default('Inconnu') %}

<span class="text-xs px-2 py-1 rounded border {{ typeBadge }}">{{ typeLabel }}</span>

