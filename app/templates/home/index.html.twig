{% extends 'base.html.twig' %}

{% block title %}Accueil — Excusatron 3000{% endblock %}

{% block body %}
    <section class="text-center py-12">
        <div class="text-6xl mb-4">🤥</div>
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900">
            Plus jamais à court d'excuses.
        </h1>
        <p class="mt-4 max-w-2xl mx-auto text-lg text-slate-600">
            Créez, générez et faites valider la meilleure excuse pour chaque situation :
            un retard, une absence, un devoir non rendu, une réunion oubliée…
            On a une excuse pour ça.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            {% if app.user %}
                <a href="{{ path('app_home') }}"
                   class="px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
                    Voir les excuses
                </a>
            {% else %}
                <a href="{{ path('app_login') }}"
                   class="px-6 py-3 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
                    Se connecter
                </a>
            {% endif %}
        </div>
    </section>

    <section class="grid gap-6 sm:grid-cols-3 mt-12">
        {% set features = [
            { icon: '✍️', title: 'Créez sur mesure', text: "Catégorie, contexte, ton : composez l'excuse parfaite selon la situation." },
            { icon: '✅', title: 'Faites-la valider', text: "Un validateur juge la crédibilité de votre excuse avant le grand jour." },
            { icon: '🏆', title: 'Gagnez des badges', text: "Notez, commentez et grimpez au classement des menteurs les plus inspirés." },
        ] %}
        {% for feature in features %}
            <div class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                <div class="text-3xl">{{ feature.icon }}</div>
                <h2 class="mt-3 font-bold text-lg text-slate-900">{{ feature.title }}</h2>
                <p class="mt-2 text-sm text-slate-600">{{ feature.text }}</p>
            </div>
        {% endfor %}
    </section>
{% endblock %}
